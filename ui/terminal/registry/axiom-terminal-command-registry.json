{
  "schema_version": "axiom.terminal.command_registry.v1",
  "purpose": "AXIOM Terminal operator command registry for the current JSON-first governance workflow.",
  "rules": {
    "clean_single_word_commands_are_primary": true,
    "axiom_prefixed_commands_are_compatibility_or_secondary": true,
    "governance_record_writes_must_use_approved_tools": true,
    "operator_accepted_requires_exact_confirmation_token": true,
    "terminal_modules_must_not_bypass_policy_or_audit": true,
    "terminal_modules_must_not_execute_runtime_or_reactivate_ipc": true
  },
  "commands": [
    {
      "name": "state",
      "category": "governance",
      "process": "observe",
      "function": "show",
      "primary": true,
      "mutates_axiom_runtime": false,
      "writes_governance_records": false,
      "authority_effect": "advisory_view",
      "risk": "low",
      "status": "implemented",
      "backing_tools": [
        "tools/operator_console.py"
      ],
      "description": "Show current JSON governance state from governance/80_records."
    },
    {
      "name": "cycle",
      "category": "governance",

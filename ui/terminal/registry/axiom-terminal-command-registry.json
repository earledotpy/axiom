    },
    {
      "name": "axiom-autonomous-posture",
      "replacement": "guard",
      "reason": "Runtime autonomy remains disabled; current terminal should emphasize governance boundaries."
    },
    {
      "name": "axiom-execution-trace",
      "replacement": "cycle",
      "reason": "Execution hub is deferred; current state is governance cycle coordination."
    }

  "blocked_direct_shortcuts": [
    {
      "name": "autonomous_operation",
      "reason": "Runtime autonomy is disabled unless separately granted and technically gated."
    },
    {
      "name": "verified_commit",
      "reason": "VERIFIED_COMMIT is deferred until the restricted verifier path exists."
    },
    {
      "name": "orchestrator_execution_hub",
